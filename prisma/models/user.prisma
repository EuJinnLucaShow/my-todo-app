model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified Boolean     @default(false) @map("email_verified")
  image         String?    
  accounts      Account[]
  sessions      Session[]  
  workspaces    Workspace[]  
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt      @map("updated_at")

  @@map("users")
}